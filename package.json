{
	"name": "pi-ghidra",
	"version": "0.1.0",
	"description": "Drive Ghidra from pi — decompile, disassemble, search, and cross-reference binaries during CTF reverse-engineering, with a cached headless project and a PyGhidra venv managed for you.",
	"type": "module",
	"keywords": [
		"pi-package",
		"ghidra",
		"pi",
		"security",
		"ctf",
		"reverse-engineering",
		"decompiler",
		"disassembler",
		"malware-analysis",
		"binary-analysis",
		"pyghidra",
		"headless"
	],
	"license": "MIT",
	"author": "not-narleeek",
	"homepage": "https://github.com/not-narleeek/pi-ghidra",
	"repository": {
		"type": "git",
		"url": "https://github.com/not-narleeek/pi-ghidra.git"
	},
	"bugs": {
		"url": "https://github.com/not-narleeek/pi-ghidra/issues"
	},
	"files": [
		"extensions",
		"scripts",
		"docs",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./extensions/ghidra.ts"
		]
	},
	"scripts": {
		"clean": "rm -rf node_modules dist",
		"check": "tsc --noEmit -p tsconfig.json",
		"py-check": "python3 -m py_compile scripts/ghidra_query.py && echo 'ghidra_query.py: syntax OK'"
	},
	"devDependencies": {
		"typescript": "^5.6.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"peerDependenciesMeta": {
		"@earendil-works/pi-ai": { "optional": false },
		"@earendil-works/pi-coding-agent": { "optional": false },
		"@earendil-works/pi-tui": { "optional": false },
		"typebox": { "optional": false }
	},
	"engines": {
		"node": ">=18"
	}
}
