# ── Dependencies / build artifacts ────────────────────────────────────────────
node_modules/
dist/
build/
*.tsbuildinfo

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.mypy_cache/
.ruff_cache/

# ── Packaging ─────────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
*.zip
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── AI agent state (never commit) ─────────────────────────────────────────────
# pi (this project's own host agent)
.pi/
# Claude Code
.claude/
# Hermes agent
.hermes/
# Cursor / Copilot / Continue
.cursor/
.continue/
# Generic agent working dirs
.agent/
agents/

# ── Ghidra / PyGhidra local state (generated at runtime) ──────────────────────
# Cached analysis projects (~/ghidra-work) and the PyGhidra venv (~/.pi/ghidra-venv)
# are created outside this repo, but ignore them if ever copied here.
ghidra-work/
ghidra-venv/
*.rep
*.gpr
*.lock

# ── Secrets & local state ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
